# Secrets — never commit
.env
.env.local
.env.*.local
*.pem
*.key

# Per-consumer Linear binding — holds the operator's real workspace/team/
# project/user UUIDs + identity. Self-describing-repo (Principle V) is
# satisfied by the committed `config-template.yml`; the resolved
# `linear-config.yml` is local-only so a public repo never leaks the
# operator's Linear coordinates. Bootstrap: copy the template, run install.
.specify/extensions/linear/linear-config.yml

# OS detritus
.DS_Store
Thumbs.db

# Editor / tooling
.vscode/
.idea/
*.swp
*.swo

# Claude Code local-only settings (skills under .claude/skills/ are tracked)
.claude/settings.local.json
# Agent worktrees — ephemeral, isolated checkouts; never committed
.claude/worktrees/
# Local MCP server wiring — machine-specific
.mcp.json

# Python build artefacts (in case the bridge ships a Python implementation)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Node build artefacts (in case the bridge ships a Node implementation)
node_modules/
dist/
build/
*.log
.npm/
.yarn/

# Spec-kit ephemera
.specify/cache/
